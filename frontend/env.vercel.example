# Copy into Vercel → Settings → Environment Variables
# Enable for "Production" (and Preview if needed). Redeploy after changes — Vite bakes VITE_* at build time.
#
# REQUIRED on deployed site: full https URL to your API (Render/Railway). Relative /api/v1 only works locally.

VITE_API_URL=https://YOUR_API_HOST.onrender.com/api/v1
VITE_SOCKET_URL=https://YOUR_API_HOST
VITE_GOOGLE_MAPS_API_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_AGORA_APP_ID=
